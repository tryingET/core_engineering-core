{
  "name": "engineering-core",
  "version": "0.2.0",
  "cli": "engineering-core",
  "model": {
    "lane": "ecosystem-specific tooling and commands",
    "addendum": "conditional lane guidance loaded only for a narrower concern",
    "discipline": "cross-language engineering invariant",
    "repo_override": "docs/engineering.local.md records local selections and deviations"
  },
  "lanes": [
    {
      "id": "py",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-py.md",
      "load_when": [
        "Python implementation",
        "FastAPI/Python service",
        "Python package or script"
      ]
    },
    {
      "id": "ts",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-ts.md",
      "load_when": [
        "General TypeScript implementation",
        "Bun-first TypeScript package/service/app"
      ]
    },
    {
      "id": "ts-frontend",
      "kind": "addendum",
      "path": "src/engineering_core/lanes/engineering-ts.frontend.md",
      "requires": [
        "ts"
      ],
      "load_when": [
        "Browser app",
        "SPA",
        "interactive frontend",
        "camera/media UI",
        "local-first frontend user data",
        "design-heavy frontend"
      ]
    },
    {
      "id": "pi-ts",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-pi-ts.md",
      "load_when": [
        "Pi extension package",
        "Node/npm Pi slash-command or prompt bundle"
      ]
    },
    {
      "id": "go",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-go.md",
      "load_when": [
        "Go implementation",
        "static binary",
        "low-operational-overhead service",
        "Go CLI"
      ]
    },
    {
      "id": "cpp",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-cpp.md",
      "load_when": [
        "C++ implementation",
        "native library",
        "ABI/native performance",
        "Python extension module"
      ]
    },
    {
      "id": "cpp-cuda",
      "kind": "addendum",
      "path": "src/engineering_core/lanes/engineering-cpp.cuda.md",
      "requires": [
        "cpp"
      ],
      "load_when": [
        "CUDA",
        "GPU kernels",
        "PyTorch C++/CUDA extensions",
        "PTX/SASS inspection",
        "GPU benchmark evidence"
      ]
    },
    {
      "id": "rust",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-rust.md",
      "load_when": [
        "Rust implementation",
        "systems code",
        "Rust service",
        "Rust CLI"
      ]
    },
    {
      "id": "elixir",
      "kind": "lane",
      "path": "src/engineering_core/lanes/engineering-elixir.md",
      "load_when": [
        "Elixir implementation",
        "Phoenix",
        "LiveView",
        "OTP service"
      ]
    },
    {
      "id": "rust-build-graph",
      "kind": "addendum",
      "path": "src/engineering_core/lanes/engineering-rust.build-graph.md",
      "requires": [
        "rust",
        "build-graph-acceleration"
      ],
      "load_when": [
        "Buck2 for Rust",
        "Bazel for Rust",
        "Rust build time bottleneck",
        "remote cache/execution for Rust",
        "large Rust workspace build acceleration"
      ]
    }
  ],
  "disciplines": [
    {
      "id": "design-system",
      "path": "src/engineering_core/disciplines/design-system.md",
      "load_when": [
        "Design tokens",
        "components",
        "motion",
        "assets",
        "visual consistency",
        "reusable UI"
      ]
    },
    {
      "id": "accessibility",
      "path": "src/engineering_core/disciplines/accessibility.md",
      "load_when": [
        "UI",
        "docs site",
        "keyboard/focus",
        "forms",
        "motion",
        "custom rendering",
        "CLI/TUI"
      ]
    },
    {
      "id": "validation",
      "path": "src/engineering_core/disciplines/validation.md",
      "load_when": [
        "Validation tiers",
        "Justfile/command surface",
        "handoff evidence",
        "CI/local checks"
      ]
    },
    {
      "id": "testing",
      "path": "src/engineering_core/disciplines/testing.md",
      "load_when": [
        "Test strategy",
        "unit/integration/E2E/property/contract tests",
        "coverage decisions"
      ]
    },
    {
      "id": "local-first-data",
      "path": "src/engineering_core/disciplines/local-first-data.md",
      "load_when": [
        "Local data",
        "persistence",
        "migrations",
        "sync",
        "generated projections",
        "corruption behavior"
      ]
    },
    {
      "id": "observability",
      "path": "src/engineering_core/disciplines/observability.md",
      "load_when": [
        "Logs",
        "metrics",
        "traces",
        "profiles",
        "health/readiness",
        "runtime evidence",
        "SLOs"
      ]
    },
    {
      "id": "security-privacy",
      "path": "src/engineering_core/disciplines/security-privacy.md",
      "load_when": [
        "Secrets",
        "permissions",
        "user data",
        "privacy",
        "dependency risk",
        "telemetry redaction"
      ]
    },
    {
      "id": "documentation",
      "path": "src/engineering_core/disciplines/documentation.md",
      "load_when": [
        "README",
        "AGENTS",
        "engineering.local",
        "architecture docs",
        "decision docs",
        "generated docs"
      ]
    },
    {
      "id": "dependency-governance",
      "path": "src/engineering_core/disciplines/dependency-governance.md",
      "load_when": [
        "Adding dependencies",
        "lockfiles",
        "native install risk",
        "package upgrades",
        "dependency removal"
      ]
    },
    {
      "id": "specification-and-dsls",
      "path": "src/engineering_core/disciplines/specification-and-dsls.md",
      "load_when": [
        "Implicit DSLs",
        "naming conventions with semantics",
        "schemas",
        "generated files",
        "policy files",
        "command vocabularies",
        "formalization decisions"
      ]
    },
    {
      "id": "engineering-reasoning",
      "path": "src/engineering_core/disciplines/engineering-reasoning.md",
      "load_when": [
        "Choosing reasoning mode",
        "abductive/deductive/inductive analysis",
        "adversarial review",
        "many-of-the-greats",
        "prompt template routing for engineering judgment"
      ]
    },
    {
      "id": "build-graph-acceleration",
      "path": "src/engineering_core/disciplines/build-graph-acceleration.md",
      "load_when": [
        "Buck2",
        "Bazel",
        "Pants",
        "Nx",
        "Turborepo",
        "remote cache",
        "remote execution",
        "build time bottlenecks",
        "secondary build graph"
      ]
    }
  ],
  "templates": [
    {
      "id": "engineering-local",
      "path": "templates/engineering.local.template.md",
      "use_for": "Repo-local selected lanes/disciplines and deviations"
    },
    {
      "id": "discipline-adoption-checklist",
      "path": "templates/discipline-adoption-checklist.md",
      "use_for": "Adopting a discipline in a concrete repo"
    },
    {
      "id": "validation-tier-map",
      "path": "templates/validation-tier-map.template.md",
      "use_for": "Mapping repo commands to validation tiers"
    },
    {
      "id": "data-classification",
      "path": "templates/data-classification.template.md",
      "use_for": "Classifying repo data and storage authority"
    },
    {
      "id": "observability-plan",
      "path": "templates/observability-plan.template.md",
      "use_for": "Planning logs, metrics, traces, health, and evidence"
    },
    {
      "id": "security-privacy-review",
      "path": "templates/security-privacy-review.template.md",
      "use_for": "Reviewing secrets, permissions, data, telemetry, and dependency risk"
    },
    {
      "id": "docs-authority-map",
      "path": "templates/docs-authority-map.template.md",
      "use_for": "Mapping repo docs to authority classes and regeneration paths"
    }
  ],
  "profiles": [
    {
      "id": "browser-app",
      "lanes": [
        "ts",
        "ts-frontend"
      ],
      "disciplines": [
        "design-system",
        "accessibility",
        "validation",
        "testing",
        "security-privacy",
        "documentation",
        "specification-and-dsls"
      ]
    },
    {
      "id": "local-first-app",
      "lanes": [],
      "disciplines": [
        "local-first-data",
        "security-privacy",
        "validation",
        "testing",
        "documentation",
        "specification-and-dsls"
      ]
    },
    {
      "id": "service-api",
      "lanes": [],
      "disciplines": [
        "validation",
        "testing",
        "observability",
        "security-privacy",
        "dependency-governance",
        "documentation",
        "specification-and-dsls"
      ]
    },
    {
      "id": "native-gpu-tool",
      "lanes": [
        "cpp",
        "cpp-cuda"
      ],
      "disciplines": [
        "validation",
        "testing",
        "observability",
        "security-privacy",
        "dependency-governance",
        "documentation",
        "build-graph-acceleration"
      ]
    },
    {
      "id": "docs-generated-ui",
      "lanes": [],
      "disciplines": [
        "documentation",
        "accessibility",
        "design-system",
        "validation",
        "specification-and-dsls"
      ]
    }
  ]
}
